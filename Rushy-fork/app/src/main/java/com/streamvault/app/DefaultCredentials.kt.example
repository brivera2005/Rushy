package com.streamvault.app

/**
 * Template for local builds. Copy to DefaultCredentials.kt (gitignored):
 *   copy DefaultCredentials.kt.example DefaultCredentials.kt
 */
object DefaultCredentials {
    const val PORTAL_URL = "http://your-xtream-portal/"
    const val USERNAME = "your_xtream_user"
    const val PASSWORD = "your_xtream_password"

    const val PLEX_SERVER_URL = "http://your-plex-server:32400"
    const val PLEX_TOKEN = "your_plex_token"

    /** Optional — Settings → Providers → Radarr / Sonarr Requests */
    const val RADARR_URL = ""
    const val RADARR_API_KEY = ""
    const val SONARR_URL = ""
    const val SONARR_API_KEY = ""

    /** When true, app startup auto-configures Xtream + Plex (+ Arr when set). */
    const val AUTO_APPLY = false
}
