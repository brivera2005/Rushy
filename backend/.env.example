# Rushy Backend Configuration
RUSHY_APP_NAME=Rushy Orchestration Engine
RUSHY_DEBUG=false
RUSHY_HOST=0.0.0.0
RUSHY_PORT=8000
RUSHY_DATABASE_URL=sqlite:///./rushy.db

# Security
RUSHY_JWT_SECRET=change-me-in-production
RUSHY_JWT_ALGORITHM=HS256
RUSHY_JWT_EXPIRE_MINUTES=1440
RUSHY_REQUIRE_USER_HEADER=true
# Comma-separated allowlist; leave empty to allow all profile IDs
RUSHY_ALLOWED_USER_IDS=

# CORS (comma-separated origins, or * for all)
RUSHY_ALLOWED_ORIGINS=*

# Scheduled Plex prune (cron hour/minute, server local time)
RUSHY_PLEX_PRUNE_HOUR=3
RUSHY_PLEX_PRUNE_MINUTE=0

# HTTP client timeout for external APIs (seconds)
RUSHY_HTTP_TIMEOUT=30

# Google Gemini API key for conversational search (optional)
GEMINI_API_KEY=

# Google Gemini API (optional — enables conversational search interpretation)
GEMINI_API_KEY=
