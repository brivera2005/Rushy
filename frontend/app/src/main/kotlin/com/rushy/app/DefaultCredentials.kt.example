package com.rushy.app

/**
 * Template for local builds. Copy to DefaultCredentials.kt (gitignored):
 *   copy DefaultCredentials.kt.example DefaultCredentials.kt
 * Fill in your portal credentials and set AUTO_APPLY = true to skip setup.
 */
object DefaultCredentials {
    const val PORTAL_URL = ""
    const val USERNAME = ""
    const val PASSWORD = ""

    /** When true, first launch auto-saves credentials and skips the setup wizard. */
    const val AUTO_APPLY = false
}
